# LLM
# Provider choices: zhipu, bailian, openai, deepseek
LLM_PROVIDER=zhipu
LLM_MODEL=glm-5.2
LLM_API_KEY=replace-with-your-key
LLM_BASE_URL=

# Embeddings
# Provider choices: zhipu, bailian, openai
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=replace-with-your-key
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=

# Reranking
# Provider choices: bailian, zhipu, none
RERANK_PROVIDER=none
RERANK_MODEL=
RERANK_API_KEY=
RERANK_BASE_URL=
ADAPTIVE_CONTEXT_ENABLED=true
ADAPTIVE_CONTEXT_MIN_SOURCES=2
ADAPTIVE_CONTEXT_SCORE_RATIO=0.5
ADAPTIVE_CONTEXT_MAX_CHARS=7200

# Optional PDF parsing fallback
MINERU_API_TOKEN=

# Optional provider-compatible keys,used when role-specific API keys above are empty.
ZAI_API_KEY=
DASHSCOPE_API_KEY=

# Optional Redis cache
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=rag:chat
REDIS_CACHE_KEY_PREFIX=rag:cache
REDIS_CACHE_TTL_SECONDS=86400

# Optional LangSmith tracing
# LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
