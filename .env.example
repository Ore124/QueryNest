# LLM setting
# LLM_PROVIDER choices: zhipu, bailian, openai, deepseek
LLM_PROVIDER=zhipu
LLM_MODEL=glm-5.2
LLM_API_KEY=replace-with-your-key
LLM_BASE_URL=

# Embedding model setting
# EMBEDDING_PROVIDER choices: zhipu, bailian, openai
# DeepSeek is intentionally not supported for embeddings.
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=replace-with-your-key
EMBEDDING_BASE_URL=
# Optional: leave empty to use the embedding model's default vector dimension.
EMBEDDING_DIMENSIONS=

# Rerank model setting
# RERANK_PROVIDER choices: bailian, zhipu, none
RERANK_PROVIDER=none
RERANK_MODEL=
RERANK_API_KEY=
RERANK_BASE_URL=

# MinerU API setting
# Required when PDF_PARSE_STRATEGY=mineru_api, or hybrid falls back to MinerU API.
MINERU_API_TOKEN=

# Legacy compatible keys
# Optional: used when role-specific API keys above are empty.
ZAI_API_KEY=
DASHSCOPE_API_KEY=

# Storage
INDEX_DIR=.rag_index
POSTGRES_DSN=postgresql://rag:rag_dev_password@127.0.0.1:5432/rag
KB_ID=default
PARSER_VERSION=document-parsers-v1
CHUNKER_VERSION=recursive-character-v1
RETRIEVAL_BM25_BACKEND=local
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION_NAME=rag_chunks
SQLITE_PATH=.sessions/rag_chat.sqlite3
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=rag:chat
REDIS_CACHE_KEY_PREFIX=rag:cache

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=
